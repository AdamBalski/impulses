FROM node:20-alpine AS build

WORKDIR /app/ui

ARG VITE_API_URL=/impulses/api
ENV VITE_API_URL=${VITE_API_URL}

COPY client-sdks/typescript /app/client-sdks/typescript
COPY ui /app/ui

RUN npm install
RUN npm run build

FROM alpine:3.20

RUN apk add --no-cache rsync

COPY --from=build /app/ui/dist /opt/ui-dist

VOLUME ["/srv/impulses"]

CMD ["sh", "-c", "mkdir -p /srv/impulses && rsync -a --delete /opt/ui-dist/ /srv/impulses/ && exec tail -f /dev/null"]
